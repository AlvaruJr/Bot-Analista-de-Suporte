import os
import pytest

def test_security_no_exposed_keys():
    """Garante que as chaves não estão escritas diretamente no código."""
    # Lista de arquivos para verificar
    files_to_check = ['especialista.py', 'app.py', 'sincronizar_emails.py']
    
    # Padrões comuns de chaves (Regex simplificado)
    forbidden_patterns = ["AIzaSy", "client_secret", "password="]
    
    for file_path in files_to_check:
        if os.path.exists(file_path):
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
                for pattern in forbidden_patterns:
                    assert pattern not in content, f"Possível chave exposta em {file_path}!"

def test_dotenv_not_empty():
    """Verifica se o .env existe e não é um arquivo vazio."""
    assert os.path.exists('.env'), "Arquivo .env ausente!"
    assert os.path.getsize('.env') > 0, "Arquivo .env está vazio!"